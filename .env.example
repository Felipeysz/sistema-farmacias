# =============================================================
# Copie este arquivo para ".env" e preencha os valores reais.
# O ".env" NUNCA deve ser commitado (já deve estar no .gitignore).
# =============================================================

# --- Postgres ---
POSTGRES_USER=farmacias_admin
POSTGRES_PASSWORD=troque-esta-senha-local
POSTGRES_DB=sistema_farmacias
N8N_DB_NAME=n8n
EVOLUTION_DB_NAME=evolution

# --- RabbitMQ ---
RABBITMQ_USER=farmacias_admin
RABBITMQ_PASSWORD=troque-esta-senha-local

# --- n8n ---
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque-esta-senha-local
# Chave que o backend usa para autenticar chamadas vindas do n8n (rotas /api/n8n/*)
N8N_BACKEND_API_KEY=gere-uma-chave-aleatoria-aqui

# --- Evolution API ---
EVOLUTION_API_KEY=gere-uma-chave-aleatoria-aqui
# Aponta para o webhook do Fluxo 1 (Atendimento) dentro do n8n, ex.:
# http://n8n:5678/webhook/whatsapp-atendimento
EVOLUTION_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp-atendimento

# --- Linear (usado pela CLI, não pelo Docker) ---
LINEAR_API_KEY=lin_api_sua_chave_aqui

# --- GitHub (usado pela CLI e futuramente pelo Actions) ---
GITHUB_TOKEN=ghp_seu_token_aqui
